APP_NAME="Festilaw"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mediumblue-oryx-470765.hostingersite.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=festilaw
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Cookie de session envoye uniquement en HTTPS (a mettre a true en production).
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# DEV : Mailtrap (bac a sable, aucun email reel delivre) -> MAIL_MAILER=smtp,
#   MAIL_HOST=sandbox.smtp.mailtrap.io, MAIL_PORT=2525, MAIL_USERNAME/MAIL_PASSWORD = inbox Mailtrap.
# PROD : Resend (transport natif via l'API HTTPS, resend/resend-php). Domaine festilaw.com verifie chez
#   Resend : DKIM sur la racine, Return-Path/bounce sur le sous-domaine send.festilaw.com ; la racine
#   reste sur Google Workspace (MX inchange). Mettre en prod :
#     MAIL_MAILER=resend
#     RESEND_API_KEY=re_xxxx        (Resend > API Keys ; jamais dans Git)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
RESEND_API_KEY=
# Expediteur : une adresse du domaine verifie (racine @festilaw.com ; PAS le sous-domaine technique send.).
MAIL_FROM_ADDRESS="no-reply@festilaw.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# Festilaw
# ------------------------------------------------------------------
#
# CHECKLIST PRODUCTION (verifiee par `php artisan festilaw:check-production` ; en APP_ENV=production
# un AVERTISSEMENT est loggue tant que ces points ne sont pas remplis, SANS bloquer le site) :
#   - PAYMENT_PROVIDERS=stripe  (+ STRIPE_SECRET_KEY et STRIPE_WEBHOOK_SECRET reels)
#   - SIGNATURE_DRIVER=signwell (+ SIGNWELL_API_KEY reelle) et SIGNWELL_TEST_MODE=false
#   - MAIL_MAILER = un vrai transport (pas "log"/"array")
#   - APP_DEBUG=false
# Les valeurs "fake"/"log"/"test" ci-dessous ne conviennent QU'EN DEV.

# Adresse qui recoit les notifications internes (soumissions, paiements...).
FESTILAW_NOTIFICATION_EMAIL=laetitia@festilaw.com

# Signature electronique : SignWell (pay-per-use), seul prestataire integre. Cle API : Settings > API.
# SIGNWELL_TEST_MODE=true : documents de test gratuits, aucun email (mettre false en prod).
# Une vraie cle de test est requise, y compris en dev (plus de bouchon local).
SIGNATURE_DRIVER=signwell

SIGNWELL_API_KEY=
SIGNWELL_API_APPLICATION_ID=
SIGNWELL_TEST_MODE=true

# Paiement : Stripe, seul prestataire integre. Cles de test requises y compris en dev.
PAYMENT_PROVIDERS=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optionnel · valeurs par defaut dans config/festilaw.php et config/logging.php.
# Delai (jours) pour regler un renouvellement annuel avant d'etre "en retard" :
# FESTILAW_RENEWAL_GRACE_DAYS=30
# Purge RGPD des dossiers abandonnes (jours apres expiration du lien de reprise) :
# FESTILAW_STARTER_ABANDONED_RETENTION_DAYS=90
# Parcours SCALE : montant de l'audit (centimes), agenda Google de reservation, validite du lien magique :
# FESTILAW_SCALE_AUDIT_CENTS=7500
# FESTILAW_SCALE_CALENDAR_URL=https://calendar.app.google/w8ZejYQLkZfgAo3F7
# FESTILAW_SCALE_RESUME_TTL_DAYS=30
# Retention des logs d'audit paiements/signature (jours) :
# LOG_AUDIT_DAYS=365

APP_NAME="Festilaw"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mediumblue-oryx-470765.hostingersite.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=festilaw
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Cookie de session envoye uniquement en HTTPS (a mettre a true en production).
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Prod : remplacer 'log' par un service transactionnel reel (Postmark/Brevo/Mailgun) et ses cles.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# Festilaw
# ------------------------------------------------------------------

# Adresse qui recoit les notifications internes (soumissions, paiements...).
FESTILAW_NOTIFICATION_EMAIL=

# Signature electronique. "fake" = aucun appel externe (defaut dev).
# Prestataire retenu : SignWell (pay-per-use). Cle API : Settings > API > "Votre cle API".
# Passer SIGNATURE_DRIVER a "signwell" une fois la cle en place.
# SIGNWELL_TEST_MODE=true : documents de test gratuits, aucun email (mettre false en prod).
SIGNATURE_DRIVER=fake

SIGNWELL_API_KEY=
SIGNWELL_API_APPLICATION_ID=
SIGNWELL_TEST_MODE=true

# Paiement (Stripe). "fake" = aucun appel externe (defaut dev).
# Passer a "stripe" (ou "stripe,paypal") une fois les cles en place.
PAYMENT_PROVIDERS=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optionnel · valeurs par defaut dans config/festilaw.php et config/logging.php.
# Delai (jours) pour regler un renouvellement annuel avant d'etre "en retard" :
# FESTILAW_RENEWAL_GRACE_DAYS=30
# Purge RGPD des dossiers abandonnes (jours apres expiration du lien de reprise) :
# FESTILAW_STARTER_ABANDONED_RETENTION_DAYS=90
# Retention des logs d'audit paiements/signature (jours) :
# LOG_AUDIT_DAYS=365
